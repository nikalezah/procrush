# PostgreSQL (default matches docker-compose.yml)
DATABASE_URL=jdbc:postgresql://localhost:5432/procrush
DATABASE_USER=procrush
DATABASE_PASSWORD=procrush

# Redis 8 (required; default matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# RabbitMQ (required; default matches docker-compose.yml)
# Default vhost "/" must be URL-encoded as %2F in the path.
RABBITMQ_URL=amqp://procrush:procrush@localhost:5672/%2F

# Kafka (required for api and matching)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Matching service — separate PostgreSQL (default matches docker-compose matching-postgres)
MATCHING_DATABASE_URL=jdbc:postgresql://localhost:5433/procrush_matching
MATCHING_DATABASE_USER=procrush
MATCHING_DATABASE_PASSWORD=procrush

# API: required — recommendations are read from matching HTTP API only
MATCHING_SERVICE_URL=http://localhost:8092

# Matching service HTTP port (не 8081/8091)
MATCHING_SERVICE_PORT=8092

# Personality service health endpoint (не 8081 — этот порт занят React dev server)
WORKER_HEALTH_PORT=8091

# Web client origins (comma-separated: React :8081, Compose :8082)
WEB_ORIGIN=http://localhost:8081,http://localhost:8082
FRONTEND_URL=http://localhost:8081

# Session cookie
SESSION_COOKIE_NAME=procrush_session
SESSION_DAYS=30

# Dev-only sign-in (POST /api/auth/dev/login). Disable in production.
AUTH_DEV_MODE=true

# Force Secure cookies (optional; auto-enabled when FRONTEND_URL / WEB_ORIGIN use https://)
# COOKIE_SECURE=true

# --- Railway (set in the Railway dashboard, not in .env) ---
# Backend (repo root, config: /railway.toml):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   RABBITMQ_URL=${{RabbitMQ.RABBITMQ_URL}}
#   KAFKA_BOOTSTRAP_SERVERS=${{Kafka.KAFKA_BOOTSTRAP_SERVERS}}
#   MATCHING_SERVICE_URL=http://${{Matching.RAILWAY_PRIVATE_DOMAIN}}:8092
#   WEB_ORIGIN=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
#   FRONTEND_URL=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
#   AUTH_DEV_MODE=false
#
# Frontend (repo root, config: /deploy/railway.frontend.toml):
#   BACKEND_UPSTREAM=${{Backend.RAILWAY_PRIVATE_DOMAIN}}:8080
#
# Personality service (repo root, config: /deploy/railway.personality.toml):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   RABBITMQ_URL=${{RabbitMQ.RABBITMQ_URL}}
#   KAFKA_BOOTSTRAP_SERVERS=${{Kafka.KAFKA_BOOTSTRAP_SERVERS}}
#   LLM_BASE_URL=...
#   LLM_API_KEY=...
#   LLM_MODEL=...
#   WORKER_HEALTH_PORT=8091
#
# Matching service (repo root, config: /deploy/railway.matching.toml):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   MATCHING_DATABASE_URL=${{MatchingPostgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   KAFKA_BOOTSTRAP_SERVERS=${{Kafka.KAFKA_BOOTSTRAP_SERVERS}}
#   MATCHING_SERVICE_PORT=8092
#
# См. раздел «Деплой на Railway» в README.md.

# --- Personality worker only (not required for API) ---
# LLM (OpenRouter — OpenAI-compatible API)
# LLM_USE_STUB=true   # только для локальной разработки без API
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-3.1-flash-lite
LLM_REQUEST_TIMEOUT_SECONDS=180
# LLM_HTTP_REFERER=https://your-app.example   # опционально, для OpenRouter
# LLM_APP_TITLE=ProCrush

# Локальный Ollama (другой формат API — определяется по URL :11434):
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama3.2
