{
  "name": "procrush-web-react",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle:openapi": "redocly bundle ../openapi/bundle.yaml -o ../openapi/dist/openapi.yaml",
    "generate:api": "openapi-typescript ../openapi/dist/openapi.yaml -o src/api/generated/schema.d.ts",
    "predev": "node scripts/check-node.mjs && npm run bundle:openapi && npm run generate:api",
    "prebuild": "node scripts/check-node.mjs && npm run bundle:openapi && npm run generate:api",
    "prepreview": "node scripts/check-node.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "openapi-typescript": "^7.6.1",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "yaml": "^2.9.0"
  }
}
