# Personality Worker — consumes RabbitMQ jobs and calls LLM.
FROM eclipse-temurin:21-jdk AS build
WORKDIR /app

COPY gradlew gradlew
COPY gradle gradle
COPY settings.gradle.kts build.gradle.kts gradle.properties ./
COPY core core
COPY server server
COPY personality-worker personality-worker

RUN chmod +x gradlew \
    && ./gradlew :personality-worker:installDist -x test --no-daemon \
        -Dorg.gradle.configuration-cache=false

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /app/personality-worker/build/install/personality-worker ./

ENV WORKER_HEALTH_PORT=8091
EXPOSE 8091

CMD ["bin/personality-worker"]
