# Personality — consumes RabbitMQ jobs and calls LLM.
FROM eclipse-temurin:25-jdk AS build
WORKDIR /app

COPY gradlew gradlew
COPY gradle gradle
COPY settings.gradle.kts build.gradle.kts gradle.properties ./
COPY i18n i18n
COPY backend backend

RUN chmod +x gradlew \
    && ./gradlew :backend:personality:installDist --no-daemon \
        -Dorg.gradle.configuration-cache=false

FROM eclipse-temurin:25-jre
WORKDIR /app
COPY --from=build /app/backend/personality/build/install/personality ./

ENV WORKER_HEALTH_PORT=8091
EXPOSE 8091

CMD ["bin/personality"]
